              "pm.test(\"Post has required fields\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
              "    pm.expect(jsonData).to.have.property(\"title\");\r",
              "    pm.expect(jsonData).to.have.property(\"body\");\r",
              "});"
