{
  "info": {
    "_postman_id": "3cec1dbc-3b67-4c21-b9c8-87a53c9868e7",
    "name": "Data-Driven Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "47741745"
  },
  "item": [
    {
      "name": "Get Multiple Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Post ID matches data file\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(parseInt(pm.variables.get(\"id\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Title matches data file\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.title).to.eql(pm.variables.get(\"title\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Body matches data file\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    let expectedBody = pm.variables.get(\"body\");\r",
              "\r",
              "    // Normalize both actual newlines AND literal \\n escape sequences\r",
              "    let actual = jsonData.body.replace(/[\\r\\n\\t\\s]+/g, ' ');\r",
              "    let expected = expectedBody\r",
              "        .replace(/\\\\n/g, ' ')       // handle literal \\n from CSV\r",
              "        .replace(/[\\r\\n\\t\\s]+/g, ' ');\r",
              "\r",
              "    pm.expect(actual.trim()).to.eql(expected.trim());\r",
              "});\r",
              "\r",
              "pm.test(\"User ID matches data file\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.userId).to.eql(parseInt(pm.variables.get(\"userId\")));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/{{id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts",
            "{{id}}"
          ]
        }
      },
      "response": []
    }
  ]
}